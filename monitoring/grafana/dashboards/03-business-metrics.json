{
  "uid": "business-metrics",
  "title": "Business Metrics",
  "description": "Domain-level KPIs: race activity, result ingestion, programme calculations, user sessions",
  "tags": ["pigeon-racing", "business"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 39,
  "time": {"from": "now-24h", "to": "now"},
  "panels": [

    { "type": "row", "title": "🏁 Race Activity", "gridPos": {"h":1,"w":24,"x":0,"y":0} },

    {
      "id": 1, "title": "Races Created (24h)",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":0,"y":1},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"increase(pigeon_races_created_total{job=\"pigeon-api\"}[24h])","legendFormat":"created"}],
      "fieldConfig": {"defaults":{"unit":"short","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 2, "title": "Races Published (24h)",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":4,"y":1},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"increase(pigeon_races_published_total{job=\"pigeon-api\"}[24h])","legendFormat":"published"}],
      "fieldConfig": {"defaults":{"unit":"short","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 3, "title": "Active Live Races",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":8,"y":1},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"pigeon_live_races_active{job=\"pigeon-api\"}","legendFormat":"live"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode":"absolute","steps":[{"color":"green","value":0},{"color":"blue","value":1}]},
          "color": {"mode":"thresholds"}
        }
      },
      "options": {"colorMode":"background"}
    },

    {
      "id": 4, "title": "Results Ingested (1h)",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":12,"y":1},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"increase(pigeon_results_ingested_total{job=\"pigeon-api\"}[1h])","legendFormat":"results"}],
      "fieldConfig": {"defaults":{"unit":"short","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 5, "title": "ETS Files Processed (24h)",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":16,"y":1},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"increase(pigeon_ets_parse_total{job=\"pigeon-api\"}[24h])","legendFormat":"files"}],
      "fieldConfig": {"defaults":{"unit":"short","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 6, "title": "Programme Calculations (24h)",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":20,"y":1},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"increase(pigeon_programme_calculations_total{job=\"pigeon-api\"}[24h])","legendFormat":"calcs"}],
      "fieldConfig": {"defaults":{"unit":"short","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 10, "title": "Race Creation Rate",
      "type": "timeseries",
      "gridPos": {"h":7,"w":12,"x":0,"y":5},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"rate(pigeon_races_created_total{job=\"pigeon-api\"}[1h]) * 3600","legendFormat":"races/hour"},
        {"datasource":{"uid":"prometheus"},"expr":"rate(pigeon_races_published_total{job=\"pigeon-api\"}[1h]) * 3600","legendFormat":"published/hour"}
      ],
      "fieldConfig": {"defaults":{"unit":"short","custom":{"lineWidth":2,"fillOpacity":10}}},
      "options": {"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]},"tooltip":{"mode":"multi"}}
    },

    {
      "id": 11, "title": "Result Ingestion Rate",
      "type": "timeseries",
      "gridPos": {"h":7,"w":12,"x":12,"y":5},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"rate(pigeon_results_ingested_total{job=\"pigeon-api\"}[5m]) * 60","legendFormat":"results/min"},
        {"datasource":{"uid":"prometheus"},"expr":"rate(pigeon_results_ingested_total{job=\"pigeon-api\",source=\"ets\"}[5m]) * 60","legendFormat":"ETS/min"},
        {"datasource":{"uid":"prometheus"},"expr":"rate(pigeon_results_ingested_total{job=\"pigeon-api\",source=\"manual\"}[5m]) * 60","legendFormat":"manual/min"}
      ],
      "fieldConfig": {"defaults":{"unit":"short","custom":{"lineWidth":2,"fillOpacity":5}}},
      "options": {"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]},"tooltip":{"mode":"multi"}}
    },

    { "type": "row", "title": "👥 User Activity", "gridPos": {"h":1,"w":24,"x":0,"y":12} },

    {
      "id": 20, "title": "Active Sessions",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":0,"y":13},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"pigeon_active_sessions{job=\"pigeon-api\"}","legendFormat":"sessions"}],
      "fieldConfig": {"defaults":{"unit":"short","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 21, "title": "Logins (1h)",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":4,"y":13},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"increase(pigeon_logins_total{job=\"pigeon-api\"}[1h])","legendFormat":"logins"}],
      "fieldConfig": {"defaults":{"unit":"short","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 22, "title": "Auth Failures (1h)",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":8,"y":13},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"increase(pigeon_auth_failures_total{job=\"pigeon-api\"}[1h])","legendFormat":"failures"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode":"absolute","steps":[{"color":"green","value":0},{"color":"yellow","value":10},{"color":"red","value":50}]},
          "color": {"mode":"thresholds"}
        }
      },
      "options": {"colorMode":"background"}
    },

    {
      "id": 23, "title": "Invitations Sent (24h)",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":12,"y":13},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"increase(pigeon_invitations_sent_total{job=\"pigeon-api\"}[24h])","legendFormat":"invites"}],
      "fieldConfig": {"defaults":{"unit":"short","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 24, "title": "Notifications Sent (24h)",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":16,"y":13},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"increase(pigeon_notifications_sent_total{job=\"pigeon-api\"}[24h])","legendFormat":"notifs"}],
      "fieldConfig": {"defaults":{"unit":"short","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 25, "title": "Token Refreshes (1h)",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":20,"y":13},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"increase(pigeon_token_refreshes_total{job=\"pigeon-api\"}[1h])","legendFormat":"refreshes"}],
      "fieldConfig": {"defaults":{"unit":"short","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 30, "title": "Login Rate & Auth Failures",
      "type": "timeseries",
      "gridPos": {"h":7,"w":12,"x":0,"y":17},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"rate(pigeon_logins_total{job=\"pigeon-api\"}[5m]) * 300","legendFormat":"logins/5min"},
        {"datasource":{"uid":"prometheus"},"expr":"rate(pigeon_auth_failures_total{job=\"pigeon-api\"}[5m]) * 300","legendFormat":"failures/5min"}
      ],
      "fieldConfig": {
        "defaults": {"unit":"short","custom":{"lineWidth":2,"fillOpacity":5}},
        "overrides": [
          {"matcher":{"id":"byName","options":"failures/5min"},"properties":[{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}]}
        ]
      },
      "options": {"legend":{"displayMode":"table","placement":"bottom","calcs":["sum"]},"tooltip":{"mode":"multi"}}
    },

    { "type": "row", "title": "⚙️ Programme Engine", "gridPos": {"h":1,"w":24,"x":0,"y":24} },

    {
      "id": 40, "title": "Calculation Duration",
      "type": "timeseries",
      "gridPos": {"h":7,"w":12,"x":0,"y":25},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"histogram_quantile(0.50, rate(pigeon_programme_calculation_duration_seconds_bucket{job=\"pigeon-api\"}[5m]))","legendFormat":"p50"},
        {"datasource":{"uid":"prometheus"},"expr":"histogram_quantile(0.95, rate(pigeon_programme_calculation_duration_seconds_bucket{job=\"pigeon-api\"}[5m]))","legendFormat":"p95"},
        {"datasource":{"uid":"prometheus"},"expr":"histogram_quantile(0.99, rate(pigeon_programme_calculation_duration_seconds_bucket{job=\"pigeon-api\"}[5m]))","legendFormat":"p99"}
      ],
      "fieldConfig": {
        "defaults": {"unit":"s","custom":{"lineWidth":2,"fillOpacity":5}},
        "overrides": [
          {"matcher":{"id":"byName","options":"p99"},"properties":[{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"p95"},"properties":[{"id":"color","value":{"fixedColor":"orange","mode":"fixed"}}]}
        ]
      },
      "options": {"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}}
    },

    {
      "id": 41, "title": "ETS Parse Success vs Failure",
      "type": "timeseries",
      "gridPos": {"h":7,"w":12,"x":12,"y":25},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"rate(pigeon_ets_parse_total{job=\"pigeon-api\"}[5m]) * 300","legendFormat":"success/5min"},
        {"datasource":{"uid":"prometheus"},"expr":"rate(pigeon_ets_parse_failures_total{job=\"pigeon-api\"}[5m]) * 300","legendFormat":"failures/5min"}
      ],
      "fieldConfig": {
        "defaults": {"unit":"short","custom":{"lineWidth":2,"fillOpacity":5}},
        "overrides": [
          {"matcher":{"id":"byName","options":"failures/5min"},"properties":[{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}]}
        ]
      },
      "options": {"legend":{"displayMode":"table","placement":"bottom","calcs":["sum"]}}
    },

    { "type": "row", "title": "📋 Business Event Logs", "gridPos": {"h":1,"w":24,"x":0,"y":32} },

    {
      "id": 50, "title": "Race & Result Events",
      "type": "logs",
      "gridPos": {"h":7,"w":24,"x":0,"y":33},
      "targets": [
        {
          "datasource": {"uid":"loki"},
          "expr": "{service=\"pigeon-api\"} | json | source_context=~\".*Race.*|.*Result.*|.*Programme.*\"",
          "legendFormat": ""
        }
      ],
      "options": {"dedupStrategy":"none","enableLogDetails":true,"showLabels":true,"showTime":true,"sortOrder":"Descending"}
    }

  ]
}
