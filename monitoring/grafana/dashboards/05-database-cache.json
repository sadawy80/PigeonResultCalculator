{
  "uid": "database-cache",
  "title": "Database & Cache",
  "description": "SQL Server query performance, EF Core connection pool, Redis hit rates, eviction and memory",
  "tags": ["pigeon-racing", "database", "redis", "cache"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {"from": "now-1h", "to": "now"},
  "panels": [

    { "type": "row", "title": "🗄️ SQL Server", "gridPos": {"h":1,"w":24,"x":0,"y":0} },

    {
      "id": 1, "title": "SQL Server Status",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":0,"y":1},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"up{job=\"sqlserver-exporter\"}","legendFormat":"Status"}],
      "fieldConfig": {
        "defaults": {
          "mappings":[{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}],
          "thresholds":{"mode":"absolute","steps":[{"color":"red","value":0},{"color":"green","value":1}]},
          "color":{"mode":"thresholds"}
        }
      },
      "options":{"reduceOptions":{"calcs":["lastNotNull"]},"graphMode":"none","textMode":"auto","colorMode":"background"}
    },

    {
      "id": 2, "title": "DB Connection Pool Available",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":4,"y":1},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"pigeon_db_connection_pool_available{job=\"pigeon-api\"}","legendFormat":"available"}],
      "fieldConfig": {
        "defaults": {
          "unit":"short",
          "thresholds":{"mode":"absolute","steps":[{"color":"red","value":0},{"color":"yellow","value":2},{"color":"green","value":10}]},
          "color":{"mode":"thresholds"}
        }
      },
      "options":{"colorMode":"background"}
    },

    {
      "id": 3, "title": "DB Pool Utilisation",
      "type": "gauge",
      "gridPos": {"h":4,"w":4,"x":8,"y":1},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"(1 - pigeon_db_connection_pool_available{job=\"pigeon-api\"} / pigeon_db_connection_pool_size{job=\"pigeon-api\"}) * 100","legendFormat":"used %"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit":"percent","min":0,"max":100,
          "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0},{"color":"yellow","value":70},{"color":"red","value":90}]},
          "color":{"mode":"thresholds"}
        }
      },
      "options":{"reduceOptions":{"calcs":["lastNotNull"]}}
    },

    {
      "id": 4, "title": "Query p50 Latency",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":12,"y":1},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"histogram_quantile(0.50, rate(pigeon_db_query_duration_seconds_bucket{job=\"pigeon-api\"}[5m]))","legendFormat":"p50"}],
      "fieldConfig": {"defaults":{"unit":"s","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 5, "title": "Query p95 Latency",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":16,"y":1},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"histogram_quantile(0.95, rate(pigeon_db_query_duration_seconds_bucket{job=\"pigeon-api\"}[5m]))","legendFormat":"p95"}],
      "fieldConfig": {
        "defaults": {
          "unit":"s",
          "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0},{"color":"yellow","value":0.5},{"color":"red","value":1}]},
          "color":{"mode":"thresholds"}
        }
      },
      "options":{"colorMode":"background"}
    },

    {
      "id": 6, "title": "Query Rate",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":20,"y":1},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"sum(rate(pigeon_db_query_duration_seconds_count{job=\"pigeon-api\"}[5m]))","legendFormat":"queries/s"}],
      "fieldConfig": {"defaults":{"unit":"reqps","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 10, "title": "DB Query Latency Percentiles",
      "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":0,"y":5},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"histogram_quantile(0.50, sum(rate(pigeon_db_query_duration_seconds_bucket{job=\"pigeon-api\"}[5m])) by (le))","legendFormat":"p50"},
        {"datasource":{"uid":"prometheus"},"expr":"histogram_quantile(0.95, sum(rate(pigeon_db_query_duration_seconds_bucket{job=\"pigeon-api\"}[5m])) by (le))","legendFormat":"p95"},
        {"datasource":{"uid":"prometheus"},"expr":"histogram_quantile(0.99, sum(rate(pigeon_db_query_duration_seconds_bucket{job=\"pigeon-api\"}[5m])) by (le))","legendFormat":"p99"}
      ],
      "fieldConfig": {
        "defaults":{"unit":"s","custom":{"lineWidth":2,"fillOpacity":5}},
        "overrides":[
          {"matcher":{"id":"byName","options":"p99"},"properties":[{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"p95"},"properties":[{"id":"color","value":{"fixedColor":"orange","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"p50"},"properties":[{"id":"color","value":{"fixedColor":"green","mode":"fixed"}}]}
        ]
      },
      "options":{"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]},"tooltip":{"mode":"multi"}}
    },

    {
      "id": 11, "title": "DB Connection Pool Over Time",
      "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":12,"y":5},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"pigeon_db_connection_pool_size{job=\"pigeon-api\"}","legendFormat":"pool size"},
        {"datasource":{"uid":"prometheus"},"expr":"pigeon_db_connection_pool_available{job=\"pigeon-api\"}","legendFormat":"available"},
        {"datasource":{"uid":"prometheus"},"expr":"pigeon_db_connection_pool_size{job=\"pigeon-api\"} - pigeon_db_connection_pool_available{job=\"pigeon-api\"}","legendFormat":"in use"}
      ],
      "fieldConfig": {
        "defaults":{"unit":"short","custom":{"lineWidth":2,"fillOpacity":10}},
        "overrides":[
          {"matcher":{"id":"byName","options":"in use"},"properties":[{"id":"color","value":{"fixedColor":"orange","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"available"},"properties":[{"id":"color","value":{"fixedColor":"green","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"pool size"},"properties":[{"id":"custom.lineStyle","value":{"fill":"dash"}}]}
        ]
      },
      "options":{"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","min"]},"tooltip":{"mode":"multi"}}
    },

    { "type": "row", "title": "⚡ Redis Cache", "gridPos": {"h":1,"w":24,"x":0,"y":13} },

    {
      "id": 20, "title": "Redis Status",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":0,"y":14},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"up{job=\"redis-exporter\"}","legendFormat":"Redis"}],
      "fieldConfig": {
        "defaults": {
          "mappings":[{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}],
          "thresholds":{"mode":"absolute","steps":[{"color":"red","value":0},{"color":"green","value":1}]},
          "color":{"mode":"thresholds"}
        }
      },
      "options":{"reduceOptions":{"calcs":["lastNotNull"]},"graphMode":"none","colorMode":"background"}
    },

    {
      "id": 21, "title": "Hit Rate",
      "type": "gauge",
      "gridPos": {"h":4,"w":4,"x":4,"y":14},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"pigeon:redis_hit_rate5m","legendFormat":"hit %"}],
      "fieldConfig": {
        "defaults": {
          "unit":"percent","min":0,"max":100,
          "thresholds":{"mode":"absolute","steps":[{"color":"red","value":0},{"color":"yellow","value":50},{"color":"green","value":80}]},
          "color":{"mode":"thresholds"}
        }
      }
    },

    {
      "id": 22, "title": "Memory Used",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":8,"y":14},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"redis_memory_used_bytes","legendFormat":"used"}],
      "fieldConfig": {"defaults":{"unit":"bytes","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 23, "title": "Memory Usage %",
      "type": "gauge",
      "gridPos": {"h":4,"w":4,"x":12,"y":14},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"(redis_memory_used_bytes / redis_config_maxmemory) * 100","legendFormat":"mem %"}],
      "fieldConfig": {
        "defaults": {
          "unit":"percent","min":0,"max":100,
          "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0},{"color":"yellow","value":70},{"color":"red","value":90}]},
          "color":{"mode":"thresholds"}
        }
      }
    },

    {
      "id": 24, "title": "Connected Clients",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":16,"y":14},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"redis_connected_clients","legendFormat":"clients"}],
      "fieldConfig": {"defaults":{"unit":"short","color":{"mode":"palette-classic"}}}
    },

    {
      "id": 25, "title": "Evicted Keys",
      "type": "stat",
      "gridPos": {"h":4,"w":4,"x":20,"y":14},
      "targets": [{"datasource":{"uid":"prometheus"},"expr":"redis_evicted_keys_total","legendFormat":"evicted"}],
      "fieldConfig": {
        "defaults": {
          "unit":"short",
          "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0},{"color":"red","value":1}]},
          "color":{"mode":"thresholds"}
        }
      },
      "options":{"colorMode":"background"}
    },

    {
      "id": 30, "title": "Cache Hit / Miss Rate",
      "type": "timeseries",
      "gridPos": {"h":7,"w":12,"x":0,"y":18},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"rate(redis_keyspace_hits_total[5m])","legendFormat":"hits/s"},
        {"datasource":{"uid":"prometheus"},"expr":"rate(redis_keyspace_misses_total[5m])","legendFormat":"misses/s"}
      ],
      "fieldConfig": {
        "defaults":{"unit":"ops","custom":{"lineWidth":2,"fillOpacity":10}},
        "overrides":[
          {"matcher":{"id":"byName","options":"hits/s"},"properties":[{"id":"color","value":{"fixedColor":"green","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"misses/s"},"properties":[{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}]}
        ]
      },
      "options":{"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]},"tooltip":{"mode":"multi"}}
    },

    {
      "id": 31, "title": "Redis Memory Over Time",
      "type": "timeseries",
      "gridPos": {"h":7,"w":12,"x":12,"y":18},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"redis_memory_used_bytes","legendFormat":"used"},
        {"datasource":{"uid":"prometheus"},"expr":"redis_memory_used_rss_bytes","legendFormat":"RSS"},
        {"datasource":{"uid":"prometheus"},"expr":"redis_config_maxmemory","legendFormat":"max"}
      ],
      "fieldConfig": {
        "defaults":{"unit":"bytes","custom":{"lineWidth":2}},
        "overrides":[
          {"matcher":{"id":"byName","options":"max"},"properties":[{"id":"custom.lineStyle","value":{"fill":"dash"}},{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}]}
        ]
      },
      "options":{"legend":{"displayMode":"table","placement":"bottom","calcs":["lastNotNull"]},"tooltip":{"mode":"multi"}}
    },

    {
      "id": 32, "title": "Redis Commands/s by Type",
      "type": "timeseries",
      "gridPos": {"h":7,"w":12,"x":0,"y":25},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"rate(redis_commands_total[5m])","legendFormat":"{{cmd}}"}
      ],
      "fieldConfig": {"defaults":{"unit":"ops","custom":{"lineWidth":1,"fillOpacity":5}}},
      "options":{"legend":{"displayMode":"table","placement":"right","calcs":["mean","max"]},"tooltip":{"mode":"multi"}}
    },

    {
      "id": 33, "title": "Redis Keyspace",
      "type": "timeseries",
      "gridPos": {"h":7,"w":12,"x":12,"y":25},
      "targets": [
        {"datasource":{"uid":"prometheus"},"expr":"redis_db_keys{db=\"db0\"}","legendFormat":"total keys"},
        {"datasource":{"uid":"prometheus"},"expr":"redis_db_keys_expiring{db=\"db0\"}","legendFormat":"expiring keys"}
      ],
      "fieldConfig": {
        "defaults":{"unit":"short","custom":{"lineWidth":2}},
        "overrides":[
          {"matcher":{"id":"byName","options":"expiring keys"},"properties":[{"id":"custom.lineStyle","value":{"fill":"dash"}}]}
        ]
      },
      "options":{"legend":{"displayMode":"table","placement":"bottom","calcs":["lastNotNull"]},"tooltip":{"mode":"multi"}}
    }

  ]
}
