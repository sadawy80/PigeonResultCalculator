{
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "placeholder-change-in-production",
    "Issuer": "PRC",
    "Audience": "PRC"
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "App": {
    "FrontendUrl": "https://localhost:4300"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Yarp.ReverseProxy": "Warning"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "clubs-route": {
        "ClusterId": "club-cluster",
        "Match": { "Path": "/api/clubs/{**catch-all}" }
      },
      "themes-route": {
        "ClusterId": "club-cluster",
        "Match": { "Path": "/api/themes/{**catch-all}" }
      },
      "notifications-route": {
        "ClusterId": "club-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "programmes-route": {
        "ClusterId": "club-cluster",
        "Match": { "Path": "/api/programmes/{**catch-all}" }
      },
      "races-route": {
        "ClusterId": "race-cluster",
        "Match": { "Path": "/api/races/{**catch-all}" }
      },
      "results-route": {
        "ClusterId": "race-cluster",
        "Match": { "Path": "/api/results/{**catch-all}" }
      },
      "livehub-route": {
        "ClusterId": "race-cluster",
        "Match": { "Path": "/hubs/live-race/{**catch-all}" }
      },
      "federationhub-route": {
        "ClusterId": "federation-cluster",
        "Match": { "Path": "/hubs/federation/{**catch-all}" }
      },
      "federation-route": {
        "ClusterId": "federation-cluster",
        "Match": { "Path": "/api/federation/{**catch-all}" }
      },
      "federation-results-route": {
        "ClusterId": "federation-cluster",
        "Match": { "Path": "/api/federation-results/{**catch-all}" }
      },
      "templates-route": {
        "ClusterId": "rendering-cluster",
        "Match": { "Path": "/api/templates/{**catch-all}" }
      },
      "integrations-route": {
        "ClusterId": "integration-cluster",
        "Match": { "Path": "/api/integrations/{**catch-all}" }
      },
      "admin-route": {
        "ClusterId": "admin-cluster",
        "Match": { "Path": "/api/admin/{**catch-all}" }
      },
      "logs-route": {
        "ClusterId": "admin-cluster",
        "Match": { "Path": "/api/logs/{**catch-all}" }
      },
      "public-route": {
        "ClusterId": "public-cluster",
        "Match": { "Path": "/api/public/{**catch-all}" }
      },
      "backup-route": {
        "ClusterId": "backup-cluster",
        "Match": { "Path": "/api/backups/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster":    { "Destinations": { "default": { "Address": "http://localhost:9501" } } },
      "club-cluster":        { "Destinations": { "default": { "Address": "http://localhost:9502" } } },
      "race-cluster":        { "Destinations": { "default": { "Address": "http://localhost:9503" } } },
      "federation-cluster":  { "Destinations": { "default": { "Address": "http://localhost:9504" } } },
      "rendering-cluster":   { "Destinations": { "default": { "Address": "http://localhost:9505" } } },
      "integration-cluster": { "Destinations": { "default": { "Address": "http://localhost:9506" } } },
      "admin-cluster":       { "Destinations": { "default": { "Address": "http://localhost:9507" } } },
      "public-cluster":      { "Destinations": { "default": { "Address": "http://localhost:9508" } } },
      "backup-cluster":      { "Destinations": { "default": { "Address": "http://localhost:9510" } } }
    }
  }
}
