      "console": "internalConsole"
    },

    // ── Angular ──────────────────────────────────────────────────────────────

    {
      "name": "Angular: Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4300",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*",
        "webpack:///src/*": "${webRoot}/*",
        "ng:///*": "${webRoot}/*"
      }
    },

    {
      "name": "Angular: Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:4300",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*",
        "webpack:///src/*": "${webRoot}/*",
        "ng:///*": "${webRoot}/*"
      }
    }
  ],

  "compounds": [

    // ── A) Full Docker Stack + Angular ────────────────────────────────────────
    {
      "name": "Full Stack: Docker + Chrome",
      "configurations": ["Angular: Chrome"],
      "preLaunchTask": "docker: start all",
      "stopAll": true
    },
    {
      "name": "Full Stack: Docker + Edge",
      "configurations": ["Angular: Edge"],
      "preLaunchTask": "docker: start all",
      "stopAll": true
    },

    // ── B) Local Gateway + Angular ────────────────────────────────────────────
    //   Run "docker: start infra" first, then start individual services manually.
    {
      "name": "Local: Gateway + Chrome",
      "configurations": ["API Gateway", "Angular: Chrome"],
      "stopAll": true
    },
    {
      "name": "Local: Gateway + Edge",
      "configurations": ["API Gateway", "Angular: Edge"],
      "stopAll": true
    }
  ]
}
