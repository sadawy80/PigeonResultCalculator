{
  "version": "0.2.0",

  // ─────────────────────────────────────────────────────────────────────────────
  //  Two workflows:
  //
  //  A) Full Docker Stack  (recommended for integration testing)
  //     Run task "docker: start all", then launch "Angular: Chrome/Edge"
  //
  //  B) Single Service Local  (for debugging a specific service)
  //     1. Run task "docker: start infra" to bring up RabbitMQ + SQL Server + Redis + Seq
  //     2. Launch the desired service config below
  //     3. Optionally also launch "Angular: Chrome" to test end-to-end
  // ─────────────────────────────────────────────────────────────────────────────

  "configurations": [

    // ── .NET: Individual Services (local run) ─────────────────────────────────

    {
      "name": "API Gateway",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build solution",
      "program": "${workspaceFolder}/backend/ApiGateway/bin/Debug/net9.0/PRC.ApiGateway.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/ApiGateway",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:9500"
      },
      "console": "internalConsole"
    },

    {
      "name": "Identity Service",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build solution",
      "program": "${workspaceFolder}/backend/IdentityService/bin/Debug/net9.0/PRC.IdentityService.dll",
