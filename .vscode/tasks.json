{
  "version": "2.0.0",
  "tasks": [

    // ── Docker Compose ──────────────────────────────────────────────────────────

    {
      "label": "docker: start infra",
      "detail": "Start infrastructure only: SQL Server, RabbitMQ, Redis, Seq",
      "type": "shell",
      "command": "docker compose up sqlserver rabbitmq redis seq -d",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared", "group": "docker" },
      "problemMatcher": []
    },

    {
      "label": "docker: start all",
      "detail": "Start the full microservices stack",
      "type": "shell",
      "command": "docker compose up -d",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "shared", "group": "docker" },
      "problemMatcher": []
    },

    {
      "label": "docker: stop all",
      "detail": "Stop all Docker Compose services",
      "type": "shell",
      "command": "docker compose down",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared", "group": "docker" },
      "problemMatcher": []
    },

    {
      "label": "docker: logs gateway",
      "detail": "Follow API gateway logs",
      "type": "shell",
      "command": "docker compose logs -f api-gateway",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "new", "group": "docker" },
      "problemMatcher": []
    },

    {
      "label": "docker: logs all",
      "detail": "Follow logs from all services",
      "type": "shell",
      "command": "docker compose logs -f",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "new", "group": "docker" },
      "problemMatcher": []
    },

    // ── .NET ────────────────────────────────────────────────────────────────────

    {
      "label": "dotnet: build solution",
      "detail": "Build the full PRC solution",
      "type": "shell",
      "command": "dotnet build backend/PRC.sln -c Debug",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": "$msCompile"
    },

    {
      "label": "dotnet: build solution (infra first)",
      "detail": "Start infrastructure in Docker, then build the .NET solution",
      "dependsOn": ["docker: start infra", "dotnet: build solution"],
      "dependsOrder": "sequence",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": "$msCompile"
    },

    // ── Angular ─────────────────────────────────────────────────────────────────

    {
      "label": "angular: install",
      "detail": "npm install in frontend",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },

    {
      "label": "angular: serve",
      "detail": "Start Angular dev-server on http://localhost:4300",
      "type": "shell",
      "command": "npm start",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "new", "group": "local" },
      "problemMatcher": {
        "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting compilation",
          "endsPattern": "Compiled successfully|compiled successfully|Browser application bundle"
        }
      }
    },

    {
      "label": "angular: build prod",
      "detail": "Production build of the Angular app",
      "type": "shell",
      "command": "npm run build -- --configuration production",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
