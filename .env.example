# ─────────────────────────────────────────────────────────────────────────────
#  PigeonRacing Platform — Environment Variables
#  Copy this file to .env and fill in your values.
#  The setup.sh script does this automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
SQL_PASSWORD=Str0ngP@ssword!

# ── Authentication ─────────────────────────────────────────────────────────────
# Must be at least 32 characters. Run: openssl rand -base64 48
JWT_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS

# ── Application URLs ──────────────────────────────────────────────────────────
# The public URL of the API (used in webhook responses sent to PLM)
API_PUBLIC_URL=https://pigeonresultcalculator.com

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
GRAFANA_DOMAIN=localhost

# ── Alerting ──────────────────────────────────────────────────────────────────
# Slack incoming webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty routing key (Events API v2)
PAGERDUTY_KEY=your-pagerduty-routing-key

# Email for critical alert notifications
ALERT_EMAIL=ops@pigeonracing.com

# ── SMTP (for email alerts and invitations) ───────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com:587
SMTP_FROM=noreply@pigeonracing.com
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password

# ── External Integrations ─────────────────────────────────────────────────────
# API key that PigeonLoftManager sends in X-PLM-Api-Key header
# (provided by PLM when they register as a partner platform)
PLM_API_KEY=change-me-get-from-pigeonloftmanager

# Secret used to sign outbound webhook payloads (HMAC-SHA256)
# Share this with PLM so they can verify callbacks are genuine
WEBHOOK_SECRET=change-me-generate-random-32-chars

# ── File Storage ──────────────────────────────────────────────────────────────
# Local file storage (default). Change to S3/Azure Blob for production.
STORAGE_TYPE=local
# STORAGE_S3_BUCKET=your-bucket
# STORAGE_S3_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
